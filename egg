                	pulseEffect.Size = Vector3.new(i*0.5, i*0.5, i*0.5)
                	pulseEffect.Transparency = 0.5 + (i * 0.05)
                	wait(0.05)
            	else
                	break
            	end
        	end
        
        	if pulseEffect and pulseEffect.Parent then
            	pulseEffect:Destroy()
        	end
    	end)
    
    	-- Function to check if the target Digimon has appeared

		local function checkForTargetDigimon(targetName)
	    	local dropsGui = player.PlayerGui:FindFirstChild("Server")
    		if dropsGui then
        		local dropsFrame = dropsGui:FindFirstChild("Drops")
        		if dropsFrame then
            		-- Loop through ALL Template objects in the Drops frame
            		for _, template in pairs(dropsFrame:GetChildren()) do
                		if template.Name == "Template" then
                    		local itemName = template:FindFirstChild("ItemName")
                    		if itemName and itemName.Text == targetName then
                        		return true
                    		end
                		end
            		end
        		end
    		end
    		return false
		end
    											
    	-- Function to call the server based on the selected type
    	local function callServerFunction()
        	if selectedType == "VIRUS" then
            	local args = {
                	[1] = player,  -- Use LocalPlayer consistently
                	[2] = "HagurumonNPC",
                	[3] = false
            	}
            	game:GetService("ReplicatedStorage"):WaitForChild("KeyBindVirus", 9e9):InvokeServer(unpack(args))
        	elseif selectedType == "DATA" then
            	local args = {
                	[1] = player,  -- Use LocalPlayer consistently
                	[2] = "HawkmonNPC",
                	[3] = false
            	}
            	game:GetService("ReplicatedStorage"):WaitForChild("KeyBindData", 9e9):InvokeServer(unpack(args))
        	elseif selectedType == "VACCINE" then
            	local args = {
                	[1] = player,  -- Use LocalPlayer consistently
                	[2] = "VeemonNPC",
                	[3] = false
            	}
            	game:GetService("ReplicatedStorage"):WaitForChild("KeyBindVaccine", 9e9):InvokeServer(unpack(args))
        	end
    	end
    
    	-- Create notification about what's happening
    	local notificationText = "OPENED: " .. selectedType
    	if selectedDigimon and selectedDigimon ~= "" then
        	notificationText = notificationText .. " - Searching for: " .. selectedDigimon
    	else
        	notificationText = notificationText .. " - Repeating: " .. repeatCount .. " times"
    	end
    
   	 	-- Display notification
    	local notificationGui = Instance.new("ScreenGui")
    	notificationGui.Name = "NotificationGui"
    	notificationGui.Parent = player.PlayerGui
    	table.insert(createdObjects, notificationGui)
    
    	local notification = Instance.new("TextLabel")
    	notification.Size = UDim2.new(0.5, 0, 0.1, 0)
    	notification.Position = UDim2.new(0.25, 0, 0.2, 0)
    	notification.Text = notificationText
    	notification.Font = Enum.Font.GothamBold
    	notification.TextColor3 = Color3.fromRGB(255, 255, 255)
    	notification.TextSize = 16
    	notification.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    	notification.BackgroundTransparency = 0.2
    
    	local notifCorner = Instance.new("UICorner")
    	notifCorner.CornerRadius = UDim.new(0, 8)
    	notifCorner.Parent = notification
    
    	local notifGradient = Instance.new("UIGradient")
   	 	notifGradient.Color = ColorSequence.new({
        	ColorSequenceKeypoint.new(0, Color3.fromRGB(111, 76, 255)),
        	ColorSequenceKeypoint.new(1, Color3.fromRGB(67, 59, 148))
    	})
    	notifGradient.Rotation = 45
    	notifGradient.Parent = notification
    
    	notification.Parent = notificationGui
	
    	-- Fade out notification after some time
    	spawn(function()
        	wait(2)
        	for i = 0, 1, 0.1 do
            	if notification and notification.Parent then
                	notification.BackgroundTransparency = 0.2 + (i * 0.8)
                	notification.TextTransparency = i
                	wait(0.05)
            	else
                	break
            	end
        	end
        	if notificationGui and notificationGui.Parent then
            	notificationGui:Destroy()
        	end
    	end)
    
    	-- Execute the server calls based on conditions
    	spawn(function()
        	if selectedDigimon and selectedDigimon ~= "" then
            	-- If searching for a specific Digimon
            	local maxAttempts = 500 -- Limit to prevent infinite loops
            	local attempts = 0
            	local found = false
            
            	repeat
                	callServerFunction()
                	attempts = attempts + 1
                	wait(0.1) -- Small delay between calls
                	found = checkForTargetDigimon(selectedDigimon)
            	until found or attempts >= maxAttempts
            
            	-- Update notification with result
            	if notification and notification.Parent then
                	if found then
                    	notification.Text = "SUCCESS: Found " .. selectedDigimon .. " after " .. attempts .. " attempts"
                    	notification.TextColor3 = Color3.fromRGB(0, 255, 0)
                	else
                    	notification.Text = "FAILED: Could not find " .. selectedDigimon .. " after " .. attempts .. " attempts"
                    	notification.TextColor3 = Color3.fromRGB(255, 0, 0)
                	end
            	end
        	else
            	-- Just repeat the specified number of times
            	print("Executing server call " .. repeatCount .. " times")
            	for i = 1, repeatCount do
                	callServerFunction()
                	wait(0.1) -- Small delay to prevent server overload
                	print("Called server function " .. i .. " of " .. repeatCount)
            	end
        	end
    	end)
	end)    
end

