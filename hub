-- Função para verificar e desconectar se moderadores estiverem no servidor
local function checkAndRemoveModerators()
    for _, player in ipairs(Players:GetPlayers()) do
        for _, moderatorId in ipairs(moderator_list) do
            if player.UserId == moderatorId then
                -- Teleportando o moderador para a nova place
                print("Moderador detectado: " .. player.Name .. " (" .. player.UserId .. ")")
                TeleportService:Teleport(114035449487554, player)
                return true
            end
        end
    end
    return false
end

-- 🛑 Remover todas as texturas
local function removeTextures()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Texture") or obj:IsA("Decal") then
            obj:Destroy()
        end
    end
end

-- 🛑 Apagar partículas e luzes
local function removeEffects()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("ParticleEmitter") or obj:IsA("PointLight") or obj:IsA("SurfaceLight") or obj:IsA("SpotLight") then
            obj:Destroy()
        end
    end
end

-- 🛑 Desativar scripts desnecessários no cliente
local function disableScripts()
    for _, obj in ipairs(game:GetDescendants()) do
        if obj:IsA("Script") and obj.Parent ~= game.ReplicatedStorage then
            obj.Disabled = true
        end
    end
end

-- 🚀 FORÇAR qualidade gráfica baixa
local function forceLowGraphics()
    local userSettings = UserSettings():GetService("UserGameSettings")
    userSettings.MasterVolume = 0  -- Se quiser também silenciar o jogo
    userSettings.SavedQualityLevel = Enum.SavedQualitySetting.QualityLevel1
    userSettings.GraphicsQualityLevel = 1

    -- Desativar sombras, reflexos e neblina
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level1
end

-- Função para iniciar as configurações selecionadas
function startFiringConfig()
    if debounceRunConfig then return end
    debounceRunConfig = true

    if isFiringConfig then
        debounceRunConfig = false
        return
    end

    -- Obter os estados atuais dos checkboxes
    checkStates.antiModerator = getCheckbox1State()  -- Usando a função getCheckbox1State para obter o estado
    checkStates.lowPlayers = getCheckbox2State()  -- Usando a função getCheckbox2State para obter o estado
	checkStates.lowTexture = getCheckbox3State()

    isFiringConfig = true

    print("Configurações ativadas:")
    print("- Anti-Moderador: " .. (checkStates.antiModerator and "SIM" or "NÃO"))
    print("- Low Players Server: " .. (checkStates.lowPlayers and "SIM" or "NÃO"))
	print("- Low Texture: " .. (checkStates.lowTexture and "SIM" or "NÃO"))

    -- Feedback visual para o botão
    TweenService:Create(runButtonConfig, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(16, 185, 129)}):Play() -- Verde
    
    -- Verificar se o LowPlayers está ativado e executar o teleporte imediatamente
    if checkStates.lowPlayers then
       	-- Chamar essa função antes do teleporte
		teleportAfterBlocking()
    end

	if checkStates.lowTexture then
		--otimizar os graficos
		-- 🏎️ Executar otimizações
		removeTextures()
		removeEffects()
		disableScripts()
		forceLowGraphics()
	end

    task.spawn(function()
        while isFiringConfig do
            if checkStates.antiModerator then
                -- Verifica moderadores a cada 5 segundos
                if checkAndRemoveModerators() then
                    -- Se um moderador for detectado, para a verificação
                    break
                end
            end

            task.wait(5)  -- Verificação a cada 5 segundos
        end

        TweenService:Create(runButtonConfig, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(217, 70, 239)}):Play() -- Volta para rosa
        debounceRunConfig = false
    end)
end

-- Função para parar a execução das configurações
function stopFiringConfig()
    if debounceStopConfig then return end
    debounceStopConfig = true
    
    -- Visual feedback for the button
    TweenService:Create(stopButtonConfig, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(16, 185, 129)}):Play() -- Verde
    
    -- Resetar visualmente as checkboxes para desmarcadas, independente do estado atual do isFiringConfig
    resetCheckbox1()  -- Resetando a primeira checkbox (antiModerator)
    resetCheckbox2()  -- Resetando a segunda checkbox (lowPlayers)
    resetCheckbox3()  -- Resetando a terceira checkbox (lowTexture)
    
    -- Resetar os estados internos das checkboxes
    checkStates.antiModerator = false
    checkStates.lowPlayers = false
    checkStates.lowTexture = false
    
    -- Se as configurações estiverem rodando, parar a execução
    if isFiringConfig then
        isFiringConfig = false
        print("Configurações desativadas.")
        
        -- Aqui você pode adicionar ações para reverter algumas das configurações aplicadas
        -- Por exemplo, se você quiser reverter as configurações gráficas:
        if checkStates.lowTexture then
            -- Restaurar configurações gráficas (opcional)
            local userSettings = UserSettings():GetService("UserGameSettings")
            userSettings.SavedQualityLevel = Enum.SavedQualitySetting.Automatic
            settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
            -- Nota: Texturas/partículas já destruídas não podem ser recuperadas
        end
    end
    
    -- Voltar a cor do botão RUN para o estado padrão se estiver verde
    TweenService:Create(runButtonConfig, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(217, 70, 239)}):Play() -- Volta para rosa
    
    -- Voltar a cor do botão STOP para o estado padrão
    task.wait(0.5)
    TweenService:Create(stopButtonConfig, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(168, 85, 247)}):Play() -- Volta para roxo
    
    task.wait(1) -- Debounce time
    debounceStopConfig = false
end

