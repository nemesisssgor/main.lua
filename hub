-- Variáveis de controle para o sistema de skills
local isFiringSkill = false

-- Função para iniciar o uso da skill selecionada
function startFiringSkill()
    if debounceRunSkill then return end
    debounceRunSkill = true
    
    if isFiringSkill then
        debounceRunSkill = false
        return
    end
    
    isFiringSkill = true
    
    -- Obtém o valor real da skill selecionada (não o texto mostrado)
    local skillName = skillDropdown.Name
    
    print("Skill selecionada para executar: " .. skillName)
    
    -- Busca o RemoteEvent correto com base no nome da skill
    local Remote = player:FindFirstChild("PlayerGui")
        and player.PlayerGui:FindFirstChild("CombatClient")
        and player.PlayerGui.CombatClient:FindFirstChild(skillName)

    if not Remote then
        warn("RemoteEvent não encontrado para a skill: " .. skillName)
        debounceRunSkill = false
        isFiringSkill = false
        return
    end

    -- Inicia o loop de execução da skill
    task.spawn(function()
        while isFiringSkill do
            local args = {
                [1] = 68889,
                [2] = 14,
                [3] = generateUniqueID(),
                [4] = false
            }
            Remote:InvokeServer(unpack(args))
            task.wait(0.1)
        end
        debounceRunSkill = false
    end)
end

-- Função para parar o uso da skill
function stopFiringSkill()
    if debounceStopSkill then return end
    debounceStopSkill = true
    
    isFiringSkill = false
    print("Parando execução da skill")
    debounceStopSkill = false
end

-- Conectando os botões às funções
runButtonSkill.MouseButton1Click:Connect(startFiringSkill)
stopButtonSkill.MouseButton1Click:Connect(stopFiringSkill)

