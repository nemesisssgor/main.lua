local TeleportService = game:GetService("TeleportService")

-- Função para teleportar para o local selecionado
function doTeleport()
    if debounceTeleport then return end
    debounceTeleport = true
    
    -- Obtém o valor do local selecionado (o valor real, não o texto exibido)
    local locationValue = teleportDropdown.Name
    local locationName = "Desconhecido"
    local placeId = nil
    
    -- Determina o nome da localização e o PlaceId baseado no valor
    if locationValue == "92975923292118" then
        locationName = "Gear Savannah"
        placeId = 92975923292118
    elseif locationValue == "138083468820287" then
        locationName = "Infinity Mountain"
        placeId = 138083468820287
    end
    
    -- Verifica se o PlaceId é válido
    if placeId then
        print("Teleportando para: " .. locationName .. " (PlaceId: " .. placeId .. ")")
        
        -- Teleporta o jogador para o PlaceId especificado
        local success, errorMessage = pcall(function()
            TeleportService:Teleport(placeId, game:GetService("Players").LocalPlayer)
        end)
        
        -- Trata possíveis erros durante o teleporte
        if not success then
            warn("Erro ao teleportar: " .. tostring(errorMessage))
            -- Opcional: Pode adicionar uma mensagem de notificação para o jogador
        else
            print("Teleporte iniciado com sucesso!")
        end
    else
        warn("PlaceId inválido para teleporte")
    end
    
    debounceTeleport = false
end

-- Conecta o botão de teleporte à função
teleportButton.MouseButton1Click:Connect(doTeleport)

