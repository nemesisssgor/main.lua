-- Variáveis de controle para o sistema de skills
local isFiringSkill = false
local debounceRunSkill = false
local debounceStopSkill = false
local currentSkill = nil  -- Mantém controle da skill ativa
local tweenRunning = false  -- Impede múltiplas animações no botão RUN

-- Função para gerar ID único (assumindo que esta função existe no código original)
local function generateUniqueID()
    return math.random(1000000, 9999999)
end

-- Função para iniciar o uso da skill selecionada
function startFiringSkill()
    if debounceRunSkill then return end
    debounceRunSkill = true

    local skillName = skillDropdown.Name  -- Obtém o nome real da skill

    -- Se já estiver executando a mesma skill, apenas sai da função
    if isFiringSkill and skillName == currentSkill then
        debounceRunSkill = false
        return
    end

    -- Se houver uma skill ativa diferente, interrompe a execução da antiga
    if isFiringSkill and skillName ~= currentSkill then
        stopFiringSkill(true)  -- Reseta tudo antes de iniciar a nova skill
    end

    -- Atualiza a skill ativa
    currentSkill = skillName
    isFiringSkill = true

    -- Verifica se a skill está disponível
    if not VerifySkill(skillName) then
        isFiringSkill = false
        debounceRunSkill = false
        return
    end

    print("Skill ativada: " .. skillName)

    -- Busca o RemoteEvent correto
    local Remote = player:FindFirstChild("PlayerGui")
        and player.PlayerGui:FindFirstChild("CombatClient")
        and player.PlayerGui.CombatClient:FindFirstChild(skillName)

    if not Remote then
        warn("RemoteEvent não encontrado para a skill: " .. skillName)
        isFiringSkill = false
        debounceRunSkill = false
        return
    end
	print("iniciando skill infinita")
    -- Inicia a execução contínua da skill
    task.spawn(function()
        while isFiringSkill do
            local args = {
                [1] = 68889,
                [2] = 14,
                [3] = generateUniqueID(),
                [4] = false
            }
            Remote:InvokeServer(unpack(args))
        end
        debounceRunSkill = false
    end)
end

-- Função para parar o uso da skill
function stopFiringSkill(fromRun)
    if debounceStopSkill then return end
    debounceStopSkill = true

    isFiringSkill = false
    currentSkill = nil  -- Reseta a skill ativa

    print("Execução de skill interrompida")

	skillImage.Image = "rbxassetid://130707804189775"

    -- Reseta a cor do botão RUN
    TweenService:Create(runButtonSkill, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(168, 85, 247)}):Play()

    -- Feedback visual para o botão STOP
    if not fromRun then
        TweenService:Create(stopButtonSkill, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(16, 185, 129)}):Play()
        task.wait(0.5)
        TweenService:Create(stopButtonSkill, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(168, 85, 247)}):Play()
    end

    task.wait(0.5)
    debounceStopSkill = false
end

