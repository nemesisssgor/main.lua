-- Função para atualizar os drops quando um Digimon for selecionado
local function updateDrops(selectedDigimon, selectedBoss)
    -- Limpar imagens antigas
    for _, child in pairs(dropFrame:GetChildren()) do
        if child:IsA("ImageLabel") then
            child:Destroy()
        end
    end

    local items = {}
    local uniqueImages = {} -- Tabela para armazenar imagens únicas

    -- Se "ALL" for selecionado, pegar os Digimons desse Boss e juntar todos os drops sem repetir
    if selectedDigimon == "ALL" and selectedBoss and digimonOptions[selectedBoss] then
        for _, digimon in ipairs(digimonOptions[selectedBoss]) do
            if digimon ~= "ALL" and dropItems[digimon] then
                for _, imageId in ipairs(dropItems[digimon]) do
                    if not uniqueImages[imageId] then -- Se a imagem ainda não foi adicionada
                        uniqueImages[imageId] = true
                        table.insert(items, imageId)
                    end
                end
            end
        end
    else
        -- Caso contrário, pegar apenas os itens do Digimon específico sem repetir
        if dropItems[selectedDigimon] then
            for _, imageId in ipairs(dropItems[selectedDigimon]) do
                if not uniqueImages[imageId] then
                    uniqueImages[imageId] = true
                    table.insert(items, imageId)
                end
            end
        end
    end

    -- Criar novos ícones de item
    for _, imageId in ipairs(items) do
        local img = Instance.new("ImageLabel")
        img.Size = UDim2.new(0, iconSize, 0, iconSize) -- Agora as imagens são fixas em 50x50 pixels
        img.BackgroundTransparency = 1
        img.Image = imageId
        img.Parent = dropFrame
    end

    -- Ajustar a rolagem corretamente para garantir que todas as imagens fiquem acessíveis
    local itemCount = #items
    local totalWidth = (iconSize + padding) * itemCount -- Largura total necessária

    -- Ajustar o CanvasSize corretamente para rolar apenas se necessário
    dropFrame.CanvasSize = UDim2.new(0, totalWidth, 1, 0)
end

