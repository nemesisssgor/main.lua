-- Function to create stylized dropdowns
local function createDropdown(parent, options, optionLabels, default, defaultLabel, yPosition)
    local dropdownContainer = Instance.new("Frame")
    dropdownContainer.Size = UDim2.new(1, 0, 0, 35)
    dropdownContainer.Position = UDim2.new(0, 0, 0, yPosition)
    dropdownContainer.BackgroundTransparency = 1
    dropdownContainer.Parent = parent
    
    local dropdown = Instance.new("TextButton")
    dropdown.Text = defaultLabel or default
    dropdown.Size = UDim2.new(1, 0, 1, 0)
    dropdown.BackgroundColor3 = Color3.fromRGB(214, 188, 250) -- Light lavender
    dropdown.TextColor3 = Color3.fromRGB(60, 7, 95) -- Dark purple
    dropdown.TextSize = 14
    dropdown.Font = Enum.Font.GothamSemibold
    dropdown.Parent = dropdownContainer
    
    local dropdownCorner = Instance.new("UICorner", dropdown)
    dropdownCorner.CornerRadius = UDim.new(0, 8)
    
    local dropdownArrow = Instance.new("TextLabel")
    dropdownArrow.Text = "▼"
    dropdownArrow.Size = UDim2.new(0, 20, 0, 20)
    dropdownArrow.Position = UDim2.new(1, -25, 0.5, -10)
    dropdownArrow.BackgroundTransparency = 1
    dropdownArrow.TextColor3 = Color3.fromRGB(91, 33, 182) -- Medium purple
    dropdownArrow.TextSize = 12
    dropdownArrow.Font = Enum.Font.GothamBold
    dropdownArrow.Parent = dropdown

    -- Store the real value (not visible to user)
    dropdown.Name = default

    -- Creating a frame with size limit to contain the menu
    local menuContainer = Instance.new("Frame")
    menuContainer.Size = UDim2.new(1, 0, 0, VISIBLE_OPTIONS * DROPDOWN_ITEM_HEIGHT)
    menuContainer.Position = UDim2.new(0, 0, 1, 5)
    menuContainer.BackgroundColor3 = Color3.fromRGB(74, 78, 76) -- Light purple
    menuContainer.ClipsDescendants = true
    menuContainer.Visible = false
    menuContainer.ZIndex = 10
    menuContainer.Parent = dropdownContainer
    
    local menuContainerCorner = Instance.new("UICorner", menuContainer)
    menuContainerCorner.CornerRadius = UDim.new(0, 8)

    -- Scrolling frame for menu
    local scroll = Instance.new("ScrollingFrame")
    scroll.Size = UDim2.new(1, 0, 1, 0)
    scroll.BackgroundTransparency = 1
    scroll.ScrollBarThickness = 4
    scroll.ScrollBarImageColor3 = Color3.fromRGB(12, 13, 14) -- Pink scrollbar
    scroll.CanvasSize = UDim2.new(0, 0, 0, #options * DROPDOWN_ITEM_HEIGHT)
    scroll.ZIndex = 10
    scroll.Parent = menuContainer

    -- If we have more than VISIBLE_OPTIONS, adjust the scrollbar to show there's more content
    if #options > VISIBLE_OPTIONS then
        scroll.CanvasPosition = Vector2.new(0, 0)  -- Start at the top
    end

    for i, option in ipairs(options) do
        local btn = Instance.new("TextButton")
        btn.Text = optionLabels and optionLabels[i] or option
        btn.Size = UDim2.new(1, -SCROLLBAR_OFFSET, 0, DROPDOWN_ITEM_HEIGHT - 5)
        btn.Position = UDim2.new(0, 5, 0, (i-1)*DROPDOWN_ITEM_HEIGHT)
        btn.BackgroundColor3 = Color3.fromRGB(0,0,0) -- Light purple-pink
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextSize = 14
        btn.Font = Enum.Font.GothamSemibold
        btn.ZIndex = 10
        btn.Parent = scroll
        
        local btnCorner = Instance.new("UICorner", btn)
        btnCorner.CornerRadius = UDim.new(0, 6)

        -- Store the real value (not visible to user)
        btn.Name = option

        btn.MouseButton1Click:Connect(function()
            dropdown.Text = btn.Text
            dropdown.Name = option  -- Store the real value
            menuContainer.Visible = false
        end)
    end

    dropdown.MouseButton1Click:Connect(function()
        menuContainer.Visible = not menuContainer.Visible

        -- Detect clicks outside the menu to close it
        if menuContainer.Visible then
            local connection
            connection = UserInputService.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    local position = input.Position
                    local guiObjects = screenGui:GetGuiObjectsAtPosition(position.X, position.Y)

                    local clickedOnMenu = false
                    for _, obj in ipairs(guiObjects) do
                        if obj:IsDescendantOf(menuContainer) or obj == dropdown then
                            clickedOnMenu = true
                            break
                        end
                    end

                    if not clickedOnMenu then
                        menuContainer.Visible = false
                        connection:Disconnect()
                    end
                end
            end)
        end
    end)

    return dropdown, menuContainer
end

-- Function to create styled buttons
local function createStyledButton(text, color, x, y, parent)
    local button = Instance.new("TextButton")
    button.Text = text
    button.Size = UDim2.new(0.45, 0, 0, 40)
    button.Position = UDim2.new(x, 0, y, 0)
    button.BackgroundColor3 = color
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.TextSize = 14
    button.Font = Enum.Font.GothamBold
    button.Parent = parent
    
    local buttonCorner = Instance.new("UICorner", button)
    buttonCorner.CornerRadius = UDim.new(0, 8)
    
    -- Create shadow effect
    local buttonShadow = Instance.new("Frame")
    buttonShadow.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    buttonShadow.BackgroundTransparency = 0.7
    buttonShadow.Size = UDim2.new(1, 0, 1, 0)
    buttonShadow.Position = UDim2.new(0, 2, 0, 2)
    buttonShadow.ZIndex = -1
    buttonShadow.Parent = button
    
    local buttonShadowCorner = Instance.new("UICorner", buttonShadow)
    buttonShadowCorner.CornerRadius = UDim.new(0, 8)
    
    -- Hover and click effects
    button.MouseEnter:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.2), {BackgroundColor3 = color:Lerp(Color3.fromRGB(255, 255, 255), 0.2)}):Play()
    end)
    
    button.MouseLeave:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.2), {BackgroundColor3 = color}):Play()
    end)
    
    button.MouseButton1Down:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.1), {Size = UDim2.new(0.45, 0, 0, 38), Position = UDim2.new(x, 0, y, 1)}):Play()
    end)
    
    button.MouseButton1Up:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.1), {Size = UDim2.new(0.45, 0, 0, 40), Position = UDim2.new(x, 0, y, 0)}):Play()
    end)
    
    return button
end


