-- Função para criar dropdowns com scroll limitado a 2 opções visíveis
local function createDropdown(parent, options, optionLabels, default, defaultLabel, yPosition)
    local dropdown = Instance.new("TextButton")
    dropdown.Text = defaultLabel or default
    dropdown.Size = UDim2.new(1, -20, 0, 30)
    dropdown.Position = UDim2.new(0, 10, 0, yPosition)
    dropdown.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    dropdown.TextColor3 = Color3.fromRGB(255, 255, 255)
    dropdown.Parent = parent
    
    -- Guarda o valor real (não visível para o usuário)
    dropdown.Name = default
    
    -- Criando um frame com limite de tamanho para conter o menu
    -- Ajustando o tamanho para mostrar apenas VISIBLE_OPTIONS itens
    local menuContainer = Instance.new("Frame")
    menuContainer.Size = UDim2.new(1, -20, 0, VISIBLE_OPTIONS * DROPDOWN_ITEM_HEIGHT)
    menuContainer.Position = UDim2.new(0, 10, 0, yPosition + 35)
    menuContainer.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    menuContainer.ClipsDescendants = true -- Importante: recorta conteúdo que sai dos limites
    menuContainer.Visible = false
    menuContainer.Parent = parent
    
    -- Frame do menu que será rolado
    local scroll = Instance.new("ScrollingFrame")
    scroll.Size = UDim2.new(1, 0, 1, 0)
    scroll.BackgroundTransparency = 1
    scroll.ScrollBarThickness = 8
    scroll.ScrollBarImageColor3 = Color3.fromRGB(255, 255, 255) -- Cor da barra de rolagem
    scroll.CanvasSize = UDim2.new(0, 0, 0, #options * DROPDOWN_ITEM_HEIGHT) -- Tamanho baseado no número de opções
    scroll.Parent = menuContainer
    
    -- Se tivermos mais que VISIBLE_OPTIONS, ajustamos a barra de rolagem para mostrar que há mais conteúdo
    if #options > VISIBLE_OPTIONS then
        scroll.CanvasPosition = Vector2.new(0, 0)  -- Começa no topo
    end

    for i, option in ipairs(options) do
        local btn = Instance.new("TextButton")
        btn.Text = optionLabels and optionLabels[i] or option
        btn.Size = UDim2.new(1, -SCROLLBAR_OFFSET, 0, DROPDOWN_ITEM_HEIGHT - 5)
        btn.Position = UDim2.new(0, 5, 0, (i-1)*DROPDOWN_ITEM_HEIGHT)
        btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.Parent = scroll
        
        -- Guarda o valor real (não visível para o usuário)
        btn.Name = option

        btn.MouseButton1Click:Connect(function()
            dropdown.Text = btn.Text
            dropdown.Name = option  -- Armazena o valor real
            menuContainer.Visible = false
        end)
    end

    dropdown.MouseButton1Click:Connect(function()
        menuContainer.Visible = not menuContainer.Visible
        
        -- Detecta cliques fora do menu para fechá-lo
        if menuContainer.Visible then
            local connection
            connection = UserInputService.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    local position = input.Position
                    local guiObjects = screenGui:GetGuiObjectsAtPosition(position.X, position.Y)
                    
                    local clickedOnMenu = false
                    for _, obj in ipairs(guiObjects) do
                        if obj:IsDescendantOf(menuContainer) or obj == dropdown then
                            clickedOnMenu = true
                            break
                        end
                    end
                    
                    if not clickedOnMenu then
                        menuContainer.Visible = false
                        connection:Disconnect()
                    end
                end
            end)
        end
    end)

    return dropdown, menuContainer
end

