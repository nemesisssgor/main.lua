-- Modify the digimon option button creation to update drops when an option is selected
local function updateDigimonDropdown(selectedBoss)
    -- Get the digimon options for the selected boss location
    local options = digimonOptions[selectedBoss] or digimonOptions["DEFAULT"]
    
    -- Clear current options in digimon dropdown
    for _, child in pairs(digimonMenu:GetChildren()) do
        if child:IsA("ScrollingFrame") then
            for _, button in pairs(child:GetChildren()) do
                if button:IsA("TextButton") then
                    button:Destroy()
                end
            end
            
            -- Update canvas size
            child.CanvasSize = UDim2.new(0, 0, 0, #options * DROPDOWN_ITEM_HEIGHT)
            
            -- Recreate option buttons
            for i, option in ipairs(options) do
                local btn = Instance.new("TextButton")
                btn.Text = option
                btn.Size = UDim2.new(1, -SCROLLBAR_OFFSET, 0, DROPDOWN_ITEM_HEIGHT - 5)
                btn.Position = UDim2.new(0, 5, 0, (i-1)*DROPDOWN_ITEM_HEIGHT)
                btn.BackgroundColor3 = Color3.fromRGB(0,0,0) -- Dark background
                btn.TextColor3 = Color3.fromRGB(255, 255, 255)
                btn.TextSize = 14
                btn.Font = Enum.Font.GothamSemibold
                btn.ZIndex = 10
                btn.Parent = child
                
                local btnCorner = Instance.new("UICorner", btn)
                btnCorner.CornerRadius = UDim.new(0, 6)
                
                -- Store the real value
                btn.Name = option
                
                btn.MouseButton1Click:Connect(function()
                    digimonDropdown.Text = btn.Text
                    digimonDropdown.Name = option
                    digimonMenu.Visible = false
                    
                    -- This is the key change - update drops immediately when a Digimon is selected
                    updateDrops(option, farmBossDropdown.Name)
                end)
            end
        end
    end
    
    -- Reset the digimon dropdown text
    digimonDropdown.Text = "SELECT DIGIMON"
    digimonDropdown.Name = "SELECT DIGIMON"
    
    -- When changing boss, we should also reset the drops display
    updateDrops("SELECT DIGIMON", selectedBoss)
end

