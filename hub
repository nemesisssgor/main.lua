-- Function to create tab buttons with images and text
local function createTabButton(text, iconId, index, total)
    local tabButton = Instance.new("TextButton")
    tabButton.Name = "Tab" .. index
    tabButton.Text = ""  -- Clear text since we'll use a separate label
    tabButton.Size = UDim2.new(1/total, -5, 1, 0)
    tabButton.Position = UDim2.new((index-1)/total, (index-1)*5, 0, 0)
    tabButton.BackgroundColor3 = Color3.fromRGB(139, 92, 246) -- Light purple for inactive tabs
    tabButton.TextColor3 = Color3.fromRGB(200, 200, 200)
    tabButton.TextSize = 14
    tabButton.Font = Enum.Font.GothamSemibold
    tabButton.Parent = tabFrame
    
    local tabCorner = Instance.new("UICorner")
    tabCorner.CornerRadius = UDim.new(0, 8)
    tabCorner.Parent = tabButton
    
    -- Create icon
    local icon = Instance.new("ImageLabel")
    icon.Size = UDim2.new(0, 30, 0, 30)
    icon.Position = UDim2.new(0.5, -15, 0.15, 0)
    icon.BackgroundTransparency = 1
    icon.Image = "rbxassetid://" .. iconId
    icon.Name = "Icon"
    icon.Parent = tabButton
    
    -- Create text label
    local label = Instance.new("TextLabel")
    label.Text = text
    label.Size = UDim2.new(1, 0, 0, 20)
    label.Position = UDim2.new(0, 0, 0.5, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.fromRGB(240, 240, 240)
    label.TextSize = 12
    label.Font = Enum.Font.GothamSemibold
    label.Name = "Label"
    label.TextXAlignment = Enum.TextXAlignment.Center
    label.Parent = tabButton
    
    return tabButton, icon, label
end

