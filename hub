    local _servers = Api.._place.."/servers/Public?sortOrder=Asc&limit=100"
    
    local function ListServers(cursor)
       local Raw = game:HttpGet(_servers .. ((cursor and "&cursor="..cursor) or ""))
       return Http:JSONDecode(Raw)
    end

    local Server, Next; repeat
       local Servers = ListServers(Next)
       Server = Servers.data[1]
       Next = Servers.nextPageCursor
    until Server

    print("Teleporting to server with ID: " .. Server.id)
    TPS:TeleportToPlaceInstance(_place, Server.id, game:GetService('Players').LocalPlayer)
end

-- Função para verificar e desconectar se moderadores estiverem no servidor
local function checkAndRemoveModerators()
    for _, player in ipairs(Players:GetPlayers()) do
        for _, moderatorId in ipairs(moderator_list) do
            if player.UserId == moderatorId then
                -- Teleportando o moderador para a nova place
                print("Moderador detectado: " .. player.Name .. " (" .. player.UserId .. ")")
                TeleportService:Teleport(114035449487554, player)
                return true
            end
        end
    end
    return false
end

-- Variáveis de controle para o sistema de configuração
local checkStates = {
    antiModerator = false,
    lowPlayers = false
}

-- Função para iniciar as configurações selecionadas
function startFiringConfig()
    if debounceRunConfig then return end
    debounceRunConfig = true

    if isFiringConfig then
        debounceRunConfig = false
        return
    end

    isFiringConfig = true

    print("Configurações ativadas:")
    print("- Anti-Moderador: " .. (checkStates.antiModerator and "SIM" or "NÃO"))
	print("- Low Players Server: " .. (checkStates.lowPlayers and "SIM" or "NÃO"))

	-- Verificar se o LowPlayers está ativado e executar o teleporte imediatamente
    if checkStates.lowPlayers then
        findLowPlayerServer()
    end

    task.spawn(function()
        while isFiringConfig do
            if checkStates.antiModerator then
                -- Verifica moderadores a cada 5 segundos
                if checkAndRemoveModerators() then
                    -- Se um moderador for detectado, para a verificação
                    break
                end
            end
            
            task.wait(5)  -- Verificação a cada 5 segundos
        end
        debounceRunConfig = false
    end)
end

-- Função para parar a execução das configurações
function stopFiringConfig()
    isFiringConfig = false
    print("Configurações desativadas.")
end

